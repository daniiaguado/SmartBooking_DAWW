{% extends 'base.html.twig' %}

{% block title %}Categorías{% endblock %}
{% block page_title %}<i class="bi bi-tags-fill me-2 text-primary"></i>Categorías{% endblock %}

{% block body %}
<div class="d-flex justify-content-end mb-3">
    <a href="{{ path('app_category_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nueva Categoría
    </a>
</div>

{% if categories is empty %}
    <div class="sb-card text-center py-5">
        <i class="bi bi-tags display-4 text-muted"></i>
        <p class="text-muted mt-3">No hay categorías creadas.</p>
        <a href="{{ path('app_category_new') }}" class="btn btn-primary">Crear primera categoría</a>
    </div>
{% else %}
    <div class="row g-3">
        {% for category in categories %}
        <div class="col-sm-6 col-lg-4">
            <div class="sb-card h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center"
                             style="width:48px;height:48px;background:{{ category.color }}20;border:2px solid {{ category.color }}40">
                            <i class="bi bi-tag-fill" style="color:{{ category.color }};font-size:1.3rem"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0">{{ category.nombre }}</h6>
                            <small class="text-muted">{{ category.resources|length }} recursos</small>
                        </div>
                    </div>
                    {% if category.descripcion %}
                        <p class="text-muted small mb-3">{{ category.descripcion }}</p>
                    {% endif %}
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_category_edit', {id: category.id}) }}"
                           class="btn btn-sm btn-outline-primary flex-grow-1">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                        <form method="post" action="{{ path('app_category_delete', {id: category.id}) }}"
                              onsubmit="return confirm('¿Eliminar esta categoría? Los recursos quedarán sin categoría.')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
