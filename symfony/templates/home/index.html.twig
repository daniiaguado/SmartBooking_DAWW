{% extends 'base.html.twig' %}

{% block title %}Inicio{% endblock %}

{% block stylesheets %}
<style>
    /* ====== GENERAL ====== */
    body { background: #f0f2f5; }

    /* ====== HERO ====== */
    .hero-section {
        background: linear-gradient(135deg, #1a2035 0%, #0d6efd 100%);
        padding: 5rem 0 4rem;
        position: relative;
        overflow: hidden;
    }
    .hero-section::before {
        content: '';
        position: absolute;
        width: 600px; height: 600px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        top: -200px; right: -150px;
        pointer-events: none;
    }
    .hero-section::after {
        content: '';
        position: absolute;
        width: 400px; height: 400px;
        border-radius: 50%;
        background: rgba(255,255,255,0.03);
        bottom: -150px; left: -100px;
        pointer-events: none;
    }
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 2rem;
        padding: 0.35rem 1rem;
        color: rgba(255,255,255,0.9);
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
    }
    .hero-title {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 800;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 1rem;
    }
    .hero-title span { color: #60a5fa; }
    .hero-subtitle {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.78);
        line-height: 1.7;
        margin-bottom: 2rem;
    }
    .btn-hero-primary {
        background: #fff;
        color: #0d6efd;
        font-weight: 700;
        border-radius: 0.6rem;
        padding: 0.8rem 2rem;
        font-size: 1rem;
        border: none;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-hero-primary:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.25);
        transform: translateY(-2px);
        color: #0b5ed7;
    }
    .btn-hero-outline {
        background: transparent;
        color: #fff;
        font-weight: 600;
        border-radius: 0.6rem;
        padding: 0.8rem 2rem;
        font-size: 1rem;
        border: 2px solid rgba(255,255,255,0.4);
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-hero-outline:hover {
        border-color: #fff;
        background: rgba(255,255,255,0.1);
        color: #fff;
        transform: translateY(-2px);
    }
    .hero-stats {
        display: flex;
        gap: 2rem;
        margin-top: 2.5rem;
        flex-wrap: wrap;
    }
    .hero-stat .number {
        font-size: 1.8rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }
    .hero-stat .label {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.6);
        margin-top: 0.2rem;
    }
    .hero-stat { border-left: 2px solid rgba(255,255,255,0.2); padding-left: 1rem; }


    /* ====== HOW IT WORKS ====== */
    .section-how {
        padding: 5rem 0;
        background: #fff;
    }
    .section-label {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #0d6efd;
        margin-bottom: 0.5rem;
    }
    .section-title {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 800;
        color: #1a2035;
        margin-bottom: 0.75rem;
    }
    .section-desc {
        color: #6c757d;
        font-size: 1rem;
        max-width: 540px;
        margin: 0 auto;
    }
    .step-card {
        text-align: center;
        padding: 2rem 1.5rem;
        border-radius: 1rem;
        transition: all 0.2s;
        position: relative;
    }
    .step-card:hover { transform: translateY(-4px); }
    .step-number {
        width: 56px; height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0d6efd, #60a5fa);
        color: #fff;
        font-size: 1.3rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        box-shadow: 0 4px 16px rgba(13,110,253,0.3);
    }
    .step-card h5 {
        font-weight: 700;
        color: #1a2035;
        margin-bottom: 0.5rem;
    }
    .step-card p {
        color: #6c757d;
        font-size: 0.9rem;
        margin: 0;
    }
    .step-connector {
        position: absolute;
        top: 28px;
        right: -30px;
        color: #dee2e6;
        font-size: 1.5rem;
        z-index: 1;
    }

    /* ====== FEATURES ====== */
    .section-features {
        padding: 5rem 0;
        background: #f8f9fa;
    }
    .feature-card {
        background: #fff;
        border-radius: 1rem;
        padding: 2rem;
        border: 1px solid #e9ecef;
        transition: all 0.2s;
        height: 100%;
    }
    .feature-card:hover {
        border-color: #0d6efd;
        box-shadow: 0 8px 32px rgba(13,110,253,0.1);
        transform: translateY(-3px);
    }
    .feature-icon {
        width: 52px; height: 52px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }
    .feature-card h5 {
        font-weight: 700;
        color: #1a2035;
        margin-bottom: 0.5rem;
        font-size: 1rem;
    }
    .feature-card p {
        color: #6c757d;
        font-size: 0.88rem;
        margin: 0;
        line-height: 1.6;
    }

    /* ====== CTA ====== */
    .section-cta {
        padding: 5rem 0;
        background: linear-gradient(135deg, #1a2035 0%, #0d6efd 100%);
    }

    /* ====== FOOTER ====== */
    .site-footer {
        background: #0f1623;
        color: rgba(255,255,255,0.7);
        padding: 3.5rem 0 1.5rem;
    }
    .footer-logo span {
        font-size: 1.3rem;
        font-weight: 800;
        color: #fff;
    }
    .footer-logo small {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.45);
        display: block;
    }
    .footer-logo-icon {
        width: 40px; height: 40px;
        background: #0d6efd;
        border-radius: 0.6rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: #fff;
        flex-shrink: 0;
    }
    .site-footer h6 {
        color: #fff;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }
    .footer-links { list-style: none; padding: 0; margin: 0; }
    .footer-links li { margin-bottom: 0.5rem; }
    .footer-links a {
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.88rem;
        transition: color 0.2s;
    }
    .footer-links a:hover { color: #60a5fa; }
    .footer-divider {
        border-color: rgba(255,255,255,0.08);
        margin: 2rem 0 1.25rem;
    }
    .footer-bottom {
        font-size: 0.82rem;
        color: rgba(255,255,255,0.4);
    }
    .footer-social a {
        width: 34px; height: 34px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.9rem;
    }
    .footer-social a:hover {
        background: #0d6efd;
        color: #fff;
    }
</style>
{% endblock %}

{% block body %}

{# ============================== HERO ============================== #}
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-lg-8 mx-auto text-center">
                <div class="hero-badge">
                    <i class="bi bi-stars"></i>
                    Sistema de Reservas Online
                </div>

                <h1 class="hero-title">
                    ¡Bienvenido a <span>SmartBooking</span>!
                </h1>

                <p class="hero-subtitle">
                    Reserva tus citas de forma rápida, segura y desde cualquier dispositivo.<br>
                    Gestiona tus reservas y consulta la disponibilidad de profesionales en un solo clic.
                </p>

                <div class="d-flex flex-wrap gap-3 justify-content-center">
                    <a href="{{ path('app_login') }}" class="btn-hero-primary">
                        <i class="bi bi-box-arrow-in-right"></i>Iniciar sesión
                    </a>
                    <a href="{{ path('app_register') }}" class="btn-hero-outline">
                        <i class="bi bi-person-plus"></i>Crear cuenta gratis
                    </a>
                </div>

                <div class="hero-stats justify-content-center">
                    <div class="hero-stat">
                        <div class="number">100%</div>
                        <div class="label">Online y seguro</div>
                    </div>
                    <div class="hero-stat">
                        <div class="number">24/7</div>
                        <div class="label">Disponible siempre</div>
                    </div>
                    <div class="hero-stat">
                        <div class="number">0€</div>
                        <div class="label">Registro gratuito</div>
                    </div>
                </div>
            </div>


        </div>
    </div>
</section>

{# ============================== CÓMO FUNCIONA ============================== #}
<section class="section-how">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Proceso sencillo</div>
            <h2 class="section-title">¿Cómo funciona SmartBooking?</h2>
            <p class="section-desc">
                En cuatro pasos sencillos tendrás tu reserva confirmada.
                Sin llamadas, sin esperas, sin complicaciones.
            </p>
        </div>

        <div class="row g-4 justify-content-center position-relative">
            <div class="col-sm-6 col-lg-3">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h5>Selecciona un profesional</h5>
                    <p>Explora el catálogo de recursos y profesionales disponibles en tu organización.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h5>Elige el servicio que deseas</h5>
                    <p>Filtra por categoría para encontrar exactamente el espacio o servicio que necesitas.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h5>Escoge la fecha que te conviene</h5>
                    <p>Consulta la disponibilidad en tiempo real y elige el horario que mejor se adapte a ti.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="step-card">
                    <div class="step-number" style="background: linear-gradient(135deg,#198754,#20c997)">
                        <i class="bi bi-check-lg" style="font-size:1.5rem"></i>
                    </div>
                    <h5>Haz clic en "Buscar"</h5>
                    <p>Confirma tu reserva al instante y recibe la confirmación. ¡Así de fácil!</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ============================== CARACTERÍSTICAS ============================== #}
<section class="section-features">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Por qué elegirnos</div>
            <h2 class="section-title">Todo lo que necesitas en un solo lugar</h2>
            <p class="section-desc">
                SmartBooking está diseñado para hacer tu día a día más eficiente.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#e7f1ff">
                        <i class="bi bi-lightning-charge-fill text-primary"></i>
                    </div>
                    <h5>Reservas al instante</h5>
                    <p>Comprueba disponibilidad y reserva en tiempo real, desde cualquier dispositivo y navegador.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#d1e7dd">
                        <i class="bi bi-shield-check-fill text-success"></i>
                    </div>
                    <h5>Seguro y fiable</h5>
                    <p>Autenticación segura con cifrado bcrypt. Tus datos siempre protegidos.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff3cd">
                        <i class="bi bi-phone-fill text-warning"></i>
                    </div>
                    <h5>Desde cualquier dispositivo</h5>
                    <p>Diseño adaptable a móvil, tablet y escritorio. Funciona en todos los navegadores.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#f8d7da">
                        <i class="bi bi-x-circle-fill text-danger"></i>
                    </div>
                    <h5>Sin conflictos</h5>
                    <p>El sistema detecta automáticamente solapamientos y te avisa antes de confirmar.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#e2d9f3">
                        <i class="bi bi-bar-chart-fill" style="color:#6f42c1"></i>
                    </div>
                    <h5>Panel de estadísticas</h5>
                    <p>Visualiza el estado de tus reservas con un dashboard claro y siempre actualizado.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#cff4fc">
                        <i class="bi bi-building-fill" style="color:#0dcaf0"></i>
                    </div>
                    <h5>Gestión de recursos</h5>
                    <p>Organiza salas, equipos y espacios con categorías y colores identificativos.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fce4ec">
                        <i class="bi bi-people-fill" style="color:#e91e63"></i>
                    </div>
                    <h5>Control de acceso</h5>
                    <p>Roles de usuario y administrador para una gestión segura y organizada.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#e8f5e9">
                        <i class="bi bi-currency-euro text-success"></i>
                    </div>
                    <h5>Precio transparente</h5>
                    <p>Ve el coste total de la reserva antes de confirmar, calculado automáticamente.</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ============================== CTA ============================== #}
<section class="section-cta">
    <div class="container text-center">
        <h2 class="fw-800 text-white mb-3" style="font-weight:800;font-size:clamp(1.6rem,3vw,2.2rem)">
            ¿Listo para empezar?
        </h2>
        <p class="text-white-50 mb-4" style="font-size:1.05rem">
            Crea tu cuenta gratis en menos de un minuto y empieza a gestionar tus reservas hoy mismo.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="{{ path('app_register') }}" class="btn-hero-primary" style="font-size:1.05rem;padding:0.9rem 2.5rem">
                <i class="bi bi-person-plus"></i>Crear cuenta gratis
            </a>
            <a href="{{ path('app_login') }}" class="btn-hero-outline" style="font-size:1.05rem;padding:0.9rem 2.5rem">
                <i class="bi bi-box-arrow-in-right"></i>Ya tengo cuenta
            </a>
        </div>
    </div>
</section>

{# ============================== FOOTER ============================== #}
<footer class="site-footer">
    <div class="container">
        <div class="row g-4">

            {# Logo y descripción #}
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3 footer-logo">
                    <div class="footer-logo-icon">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <div>
                        <span>SmartBooking</span>
                        <small>Sistema de Gestión de Reservas</small>
                    </div>
                </div>
                <p style="font-size:.88rem;line-height:1.7;color:rgba(255,255,255,0.55)">
                    Plataforma web open source para la gestión de reservas de recursos compartidos.
                    Rápida, segura y accesible desde cualquier dispositivo.
                </p>
                <div class="footer-social d-flex gap-2 mt-3">
                    <a href="#" title="GitHub"><i class="bi bi-github"></i></a>
                    <a href="#" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    <a href="#" title="Email"><i class="bi bi-envelope"></i></a>
                </div>
            </div>

            {# Navegación #}
            <div class="col-6 col-lg-2">
                <h6>Plataforma</h6>
                <ul class="footer-links">
                    <li><a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Inicio</a></li>
                    <li><a href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesión</a></li>
                    <li><a href="{{ path('app_register') }}"><i class="bi bi-person-plus me-1"></i>Registrarse</a></li>
                    <li><a href="{{ path('app_resource_index') }}"><i class="bi bi-building me-1"></i>Recursos</a></li>
                </ul>
            </div>

            {# Cómo funciona #}
            <div class="col-6 col-lg-3">
                <h6>Cómo funciona</h6>
                <ul class="footer-links">
                    <li><a href="#"><i class="bi bi-1-circle me-1"></i>Selecciona un profesional</a></li>
                    <li><a href="#"><i class="bi bi-2-circle me-1"></i>Elige el servicio</a></li>
                    <li><a href="#"><i class="bi bi-3-circle me-1"></i>Escoge la fecha</a></li>
                    <li><a href="#"><i class="bi bi-search me-1"></i>Busca disponibilidad</a></li>
                </ul>
            </div>

        </div>

        <hr class="footer-divider">

        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 footer-bottom">
            <span>
                &copy; {{ "now"|date("Y") }} SmartBooking · Proyecto Final de Ciclo DAW ·
                Florida Centre de Formació Coop. V.
            </span>
            <span class="d-flex align-items-center gap-1">
                Hecho con <i class="bi bi-heart-fill text-danger mx-1" style="font-size:.7rem"></i> por Daniel Aguado
            </span>
        </div>
    </div>
</footer>

{% endblock %}
