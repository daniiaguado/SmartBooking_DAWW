{% extends 'base.html.twig' %}

{% block title %}Recursos{% endblock %}
{% block page_title %}<i class="bi bi-building me-2 text-primary"></i>Recursos Disponibles{% endblock %}

{% block body %}

{# Angular resource filter #}
<app-resource-filter
    filter-action="{{ path('app_resource_index') }}"
    current-nombre="{{ filtros.nombre ?? '' }}"
    current-capacity="{{ filtros.capacidad ?? '' }}">
</app-resource-filter>

{# Filtros HTML fallback #}
<div class="sb-card mb-4">
    <div class="card-body">
        <form method="get" action="{{ path('app_resource_index') }}" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Nombre</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="nombre" class="form-control"
                           value="{{ filtros.nombre ?? '' }}" placeholder="Buscar recurso...">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Categoría</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {{ filtros.categoryId == cat.id ? 'selected' }}>
                            {{ cat.nombre }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Capacidad mín.</label>
                <input type="number" name="capacidad" class="form-control form-control-sm"
                       value="{{ filtros.capacidad ?? '' }}" min="1" placeholder="1">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                <a href="{{ path('app_resource_index') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">{{ resources|length }} recursos encontrados</span>
    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('app_resource_new') }}" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Recurso
    </a>
    {% endif %}
</div>

{% if resources is empty %}
    <div class="sb-card text-center py-5">
        <i class="bi bi-building display-4 text-muted"></i>
        <p class="text-muted mt-3">No se encontraron recursos.</p>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_resource_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Crear primer recurso
        </a>
        {% endif %}
    </div>
{% else %}
    <div class="row g-3" id="resourcesGrid">
        {% for resource in resources %}
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="sb-card h-100 resource-card" data-category="{{ resource.category ? resource.category.id : 0 }}">
                <div class="card-body d-flex flex-column p-3">
                    {# Category color strip #}
                    <div class="rounded-2 mb-3 d-flex align-items-center justify-content-center text-white fw-bold"
                         style="height:80px;background:{{ resource.category ? resource.category.color : '#6c757d' }}">
                        <i class="bi bi-building" style="font-size:2rem"></i>
                    </div>

                    <div class="flex-grow-1">
                        <h6 class="fw-bold mb-1">{{ resource.nombre }}</h6>
                        {% if resource.category %}
                            <span class="badge mb-2" style="background:{{ resource.category.color }}20;color:{{ resource.category.color }};border:1px solid {{ resource.category.color }}40">
                                {{ resource.category.nombre }}
                            </span>
                        {% endif %}
                        {% if resource.descripcion %}
                            <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                {{ resource.descripcion }}
                            </p>
                        {% endif %}
                    </div>

                    <div class="border-top pt-2 mt-2">
                        <div class="row g-1 text-center small">
                            <div class="col-6">
                                <div class="text-muted">Capacidad</div>
                                <strong><i class="bi bi-people me-1"></i>{{ resource.capacidad }}</strong>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Precio/h</div>
                                <strong class="text-primary">{{ resource.precioHora }}€</strong>
                            </div>
                        </div>
                        {% if resource.ubicacion %}
                        <div class="text-muted small mt-1 text-center">
                            <i class="bi bi-geo-alt me-1"></i>{{ resource.ubicacion }}
                        </div>
                        {% endif %}
                    </div>

                    <div class="d-flex gap-1 mt-3">
                        <a href="{{ path('app_resource_show', {id: resource.id}) }}"
                           class="btn btn-sm btn-outline-primary flex-grow-1">
                            <i class="bi bi-eye me-1"></i>Ver
                        </a>
                        <a href="{{ path('app_booking_new') }}"
                           class="btn btn-sm btn-primary flex-grow-1">
                            <i class="bi bi-calendar-plus me-1"></i>Reservar
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_resource_edit', {id: resource.id}) }}"
                           class="btn btn-sm btn-outline-secondary" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
