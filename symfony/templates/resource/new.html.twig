{% extends 'base.html.twig' %}

{% block title %}Nuevo Recurso{% endblock %}
{% block page_title %}<i class="bi bi-plus-circle me-2 text-primary"></i>Nuevo Recurso{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="sb-card">
            <div class="card-body p-4">
                <app-form-validator form-id="resourceForm"></app-form-validator>

                {{ form_start(form, {'attr': {'id': 'resourceForm', 'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(form.nombre) }}
                    {{ form_widget(form.nombre) }}
                    {{ form_errors(form.nombre) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.category) }}
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.descripcion) }}
                    {{ form_widget(form.descripcion) }}
                    {{ form_errors(form.descripcion) }}
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        {{ form_label(form.capacidad) }}
                        {{ form_widget(form.capacidad) }}
                        {{ form_errors(form.capacidad) }}
                    </div>
                    <div class="col-sm-6">
                        {{ form_label(form.ubicacion) }}
                        {{ form_widget(form.ubicacion) }}
                        {{ form_errors(form.ubicacion) }}
                    </div>
                </div>
                <div class="mb-3">
                    {{ form_label(form.precioHora) }}
                    {{ form_widget(form.precioHora) }}
                    {{ form_errors(form.precioHora) }}
                </div>
                <div class="mb-4 form-check">
                    {{ form_widget(form.isActive) }}
                    {{ form_label(form.isActive) }}
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a href="{{ path('app_resource_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i>Crear Recurso
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
