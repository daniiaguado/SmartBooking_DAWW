{% extends 'base.html.twig' %}

{% block title %}Editar Reserva #{{ booking.id }}{% endblock %}
{% block page_title %}<i class="bi bi-pencil-square me-2 text-primary"></i>Editar Reserva #{{ booking.id }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="alert alert-info mb-4 d-flex align-items-center gap-2">
            <i class="bi bi-info-circle-fill"></i>
            <span>
                Reserva creada el {{ booking.createdAt|date('d/m/Y H:i') }}.
                Estado actual:
                <span class="badge badge-{{ booking.estado }} ms-1">{{ booking.estado|capitalize }}</span>
            </span>
        </div>

        <div class="sb-card">
            <div class="card-body p-4">

                <app-form-validator form-id="editBookingForm"></app-form-validator>

                {{ form_start(form, {'attr': {'id': 'editBookingForm', 'novalidate': 'novalidate'}}) }}

                <div class="mb-4">
                    {{ form_label(form.resource) }}
                    {{ form_widget(form.resource) }}
                    {{ form_errors(form.resource) }}
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        {{ form_label(form.fechaInicio) }}
                        {{ form_widget(form.fechaInicio) }}
                        {{ form_errors(form.fechaInicio) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.fechaFin) }}
                        {{ form_widget(form.fechaFin) }}
                        {{ form_errors(form.fechaFin) }}
                    </div>
                </div>

                <div class="mb-4">
                    {{ form_label(form.asistentes) }}
                    {{ form_widget(form.asistentes) }}
                    {{ form_errors(form.asistentes) }}
                </div>

                <div class="mb-4">
                    {{ form_label(form.motivo) }}
                    {{ form_widget(form.motivo) }}
                    {{ form_errors(form.motivo) }}
                </div>

                {% if form.estado is defined %}
                <div class="mb-4">
                    {{ form_label(form.estado) }}
                    {{ form_widget(form.estado) }}
                </div>
                {% endif %}

                <div class="d-flex gap-2 justify-content-end">
                    <a href="{{ path('app_booking_show', {id: booking.id}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Volver
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i>Guardar Cambios
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
