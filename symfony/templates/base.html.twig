<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SmartBooking{% endblock %} – SmartBooking</title>

    {# Bootstrap 5 CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {# Angular compiled styles #}
    {% if asset('build/styles.css') is defined %}
        <link rel="stylesheet" href="{{ asset('build/styles.css') }}">
    {% endif %}

    <style>
        :root {
            --sb-primary: #0d6efd;
            --sb-sidebar-bg: #1a2035;
            --sb-sidebar-text: #adb5bd;
            --sb-sidebar-active: #ffffff;
        }

        body { background-color: #f0f2f5; min-height: 100vh; }

        /* Sidebar */
        .sb-sidebar {
            width: 260px;
            min-height: 100vh;
            background: var(--sb-sidebar-bg);
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            transition: transform 0.3s ease;
        }
        .sb-sidebar .sb-logo {
            padding: 1.5rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .sb-sidebar .sb-logo span { font-size: 1.3rem; font-weight: 700; color: #fff; }
        .sb-sidebar .sb-logo small { color: var(--sb-sidebar-text); font-size: 0.75rem; }
        .sb-sidebar .nav-link {
            color: var(--sb-sidebar-text);
            padding: 0.6rem 1.25rem;
            border-radius: 0.5rem;
            margin: 0.1rem 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            transition: all 0.2s;
            font-size: 0.9rem;
        }
        .sb-sidebar .nav-link:hover,
        .sb-sidebar .nav-link.active {
            color: var(--sb-sidebar-active);
            background: rgba(255,255,255,0.1);
        }
        .sb-sidebar .nav-link i { font-size: 1rem; width: 1.2rem; text-align: center; }
        .sb-sidebar .nav-section {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            color: #6c757d;
            padding: 1rem 1.25rem 0.25rem 2rem;
            text-transform: uppercase;
        }

        /* Main content */
        .sb-main { margin-left: 260px; padding: 1.5rem; }

        /* Topbar */
        .sb-topbar {
            background: #fff;
            border-radius: 0.75rem;
            padding: 0.75rem 1.25rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .sb-topbar .page-title { font-weight: 600; font-size: 1.1rem; margin: 0; }

        /* Cards */
        .sb-card {
            background: #fff;
            border-radius: 0.75rem;
            border: none;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        /* Estado badges */
        .badge-pendiente  { background-color: #ffc107; color: #000; }
        .badge-confirmada { background-color: #198754; color: #fff; }
        .badge-cancelada  { background-color: #dc3545; color: #fff; }

        /* Responsive */
        @media (max-width: 768px) {
            .sb-sidebar { transform: translateX(-100%); }
            .sb-sidebar.show { transform: translateX(0); }
            .sb-main { margin-left: 0; }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

{% if app.user %}
{# ======================== SIDEBAR ======================== #}
<nav class="sb-sidebar d-flex flex-column">
    <div class="sb-logo">
        <div class="d-flex align-items-center gap-2">
            <div class="rounded-3 bg-primary d-flex align-items-center justify-content-center" style="width:36px;height:36px">
                <i class="bi bi-calendar-check text-white fs-5"></i>
            </div>
            <div>
                <span>SmartBooking</span><br>
                <small>Sistema de Reservas</small>
            </div>
        </div>
    </div>

    <div class="flex-grow-1 overflow-auto py-2">
        <div class="nav-section">Principal</div>
        <a href="{{ path('app_dashboard') }}"
           class="nav-link {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' }}">
            <i class="bi bi-grid-1x2-fill"></i> Dashboard
        </a>
        <a href="{{ path('app_booking_index') }}"
           class="nav-link {{ app.request.attributes.get('_route') starts with 'app_booking' ? 'active' }}">
            <i class="bi bi-calendar3"></i> Mis Reservas
        </a>
        <a href="{{ path('app_booking_new') }}" class="nav-link">
            <i class="bi bi-plus-circle"></i> Nueva Reserva
        </a>
        <a href="{{ path('app_resource_index') }}"
           class="nav-link {{ app.request.attributes.get('_route') starts with 'app_resource' ? 'active' }}">
            <i class="bi bi-building"></i> Recursos
        </a>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="nav-section">Administración</div>
        <a href="{{ path('app_category_index') }}"
           class="nav-link {{ app.request.attributes.get('_route') starts with 'app_category' ? 'active' }}">
            <i class="bi bi-tags-fill"></i> Categorías
        </a>
        {% endif %}
    </div>

    <div class="border-top border-secondary p-3" style="border-color: rgba(255,255,255,0.08)!important">
        <div class="d-flex align-items-center gap-2 mb-2">
            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                 style="width:34px;height:34px;font-size:.85rem">
                {{ app.user.nombre|first|upper }}{{ app.user.apellidos|first|upper }}
            </div>
            <div style="line-height:1.2">
                <div class="text-white" style="font-size:.85rem;font-weight:600">{{ app.user.nombre }}</div>
                <div style="font-size:.7rem;color:#6c757d">{{ app.user.email }}</div>
            </div>
        </div>
        <a href="{{ path('app_logout') }}" class="nav-link text-danger">
            <i class="bi bi-box-arrow-right"></i> Cerrar sesión
        </a>
    </div>
</nav>
{% endif %}

{# ======================== MAIN CONTENT ======================== #}
<main class="{{ app.user ? 'sb-main' : '' }}">

    {% if app.user %}
    <div class="sb-topbar">
        <h1 class="page-title">{% block page_title %}SmartBooking{% endblock %}</h1>
        <div class="d-flex align-items-center gap-2">
            {% if is_granted('ROLE_ADMIN') %}
                <span class="badge bg-danger"><i class="bi bi-shield-fill"></i> Admin</span>
            {% endif %}
            <span class="text-muted small">{{ "now"|date("d/m/Y") }}</span>
        </div>
    </div>
    {% endif %}

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show mb-3"
                 role="alert" id="flash-{{ loop.index }}">
                {% if type == 'success' %}<i class="bi bi-check-circle-fill me-2"></i>{% endif %}
                {% if type == 'danger' %}<i class="bi bi-exclamation-triangle-fill me-2"></i>{% endif %}
                {% if type == 'warning' %}<i class="bi bi-exclamation-circle-fill me-2"></i>{% endif %}
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{# ======================== ANGULAR ELEMENTS ======================== #}
{# Angular Elements se inicializan al cargar el bundle.
   <app-root> no se usa: cada componente se registra como Web Component. #}
<app-toast></app-toast>

{# Bootstrap JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{# Angular compiled bundle #}
<script src="{{ asset('build/runtime.js') }}" defer></script>
<script src="{{ asset('build/polyfills.js') }}" defer></script>
<script src="{{ asset('build/main.js') }}" defer></script>

<script>
    // Auto-dismiss flash messages after 5s
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[id^="flash-"]').forEach(el => {
            setTimeout(() => {
                const bsAlert = bootstrap.Alert.getOrCreateInstance(el);
                bsAlert.close();
            }, 5000);
        });
    });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
