<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SmartBooking{% endblock %} – SmartBooking</title>

    {# Bootstrap 5 CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    {# Google Font: Inter #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    {# Angular compiled styles #}
    {% if asset('build/styles.css') is defined %}
        <link rel="stylesheet" href="{{ asset('build/styles.css') }}">
    {% endif %}

    {# SmartBooking custom CSS – archivo físico, cargado después de Bootstrap para sobreescribir #}
    <link rel="stylesheet" href="{{ asset('css/smartbooking.css') }}">

    <style>
        /* ── Paleta SmartBooking ───────────────────────────────────────────── */
        :root {
            --sb-primary:        #6366f1;
            --sb-primary-dark:   #4f46e5;
            --sb-primary-light:  #e0e7ff;
            --sb-secondary:      #0ea5e9;
            --sb-success:        #10b981;
            --sb-warning:        #f59e0b;
            --sb-danger:         #ef4444;
            --sb-dark:           #0f172a;
            --sb-sidebar-bg:     #0f172a;
            --sb-sidebar-text:   #94a3b8;
            --sb-sidebar-active: #6366f1;
            --sb-body-bg:        #f8fafc;
            --sb-card-shadow:    0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
        }

        /* ── Tipografía base ──────────────────────────────────────────────── */
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--sb-body-bg);
            min-height: 100vh;
            color: #1e293b;
        }

        /* ── Override color primario de Bootstrap ─────────────────────────── */
        .btn-primary {
            background: linear-gradient(135deg, var(--sb-primary), var(--sb-primary-dark));
            border-color: var(--sb-primary-dark);
            border-radius: 8px;
            font-weight: 500;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .btn-primary:hover, .btn-primary:focus {
            background: linear-gradient(135deg, var(--sb-primary-dark), #4338ca);
            border-color: #4338ca;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(99,102,241,.35);
        }
        .btn-outline-primary {
            color: var(--sb-primary);
            border-color: var(--sb-primary);
            border-radius: 8px;
            font-weight: 500;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .btn-outline-primary:hover {
            background: var(--sb-primary);
            border-color: var(--sb-primary);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(99,102,241,.25);
        }
        .btn-outline-secondary { border-radius: 8px; font-weight: 500; transition: transform 0.15s; }
        .btn-outline-secondary:hover { transform: translateY(-1px); }
        .btn-sm { border-radius: 6px !important; }
        .text-primary { color: var(--sb-primary) !important; }
        .bg-primary   { background-color: var(--sb-primary) !important; }

        /* ── Navbar superior ──────────────────────────────────────────────── */
        .sb-topnav {
            background: #0f172a !important;
            border-bottom: 1px solid rgba(255,255,255,0.08) !important;
            padding: 0 24px !important;
            height: 60px;
            z-index: 1030;
        }
        .sb-topnav .navbar-brand {
            color: #fff !important;
            font-weight: 700 !important;
            font-size: 1rem !important;
            display: flex; align-items: center; gap: 10px;
        }
        .sb-topnav .navbar-brand .logo-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--sb-primary), var(--sb-primary-dark));
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(99,102,241,.4);
        }
        .sb-topnav .nav-link {
            color: #94a3b8 !important;
            padding: 8px 14px !important;
            border-radius: 8px !important;
            font-size: 0.875rem !important;
            font-weight: 500 !important;
            transition: all 0.2s !important;
            display: flex; align-items: center; gap: 6px;
        }
        .sb-topnav .nav-link:hover { color: #fff !important; background: rgba(255,255,255,0.08) !important; }
        .sb-topnav .nav-link.active { color: #a5b4fc !important; background: rgba(99,102,241,0.15) !important; }
        .sb-topnav .navbar-toggler { border-color: rgba(255,255,255,.2); }
        .sb-topnav .navbar-toggler-icon { filter: invert(1); }
        .sb-topnav .dropdown-menu {
            border: 1px solid rgba(0,0,0,.1);
            border-radius: 10px;
            box-shadow: 0 8px 24px rgba(0,0,0,.12);
            min-width: 200px;
        }
        .sb-topnav .dropdown-item { font-size: .875rem; padding: .5rem 1rem; }
        .sb-topnav .dropdown-item:hover { background: #f0f4ff; color: var(--sb-primary); }
        .sb-user-avatar {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--sb-primary), var(--sb-secondary));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-size: .8rem;
            font-weight: 700;
            flex-shrink: 0;
        }
        .sb-notif-btn {
            position: relative;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 8px;
            width: 36px; height: 36px;
            display: flex; align-items: center; justify-content: center;
            color: #94a3b8;
            cursor: pointer;
            transition: background 0.15s, box-shadow 0.15s;
            text-decoration: none;
        }
        .sb-notif-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }
        .sb-notif-dot {
            position: absolute;
            top: 5px; right: 5px;
            width: 8px; height: 8px;
            background: var(--sb-danger);
            border-radius: 50%;
            border: 1.5px solid #0f172a;
        }

        /* ── Main content ─────────────────────────────────────────────────── */
        .sb-main-content {
            padding-top: 76px;
            min-height: 100vh;
            background: var(--sb-body-bg, #f1f5f9);
            padding-left: 1.5rem;
            padding-right: 1.5rem;
            padding-bottom: 3rem;
        }

        /* ── Cards ────────────────────────────────────────────────────────── */
        .sb-card {
            background: #fff;
            border-radius: 12px;
            border: none;
            box-shadow: var(--sb-card-shadow);
            transition: box-shadow 0.2s ease;
        }
        .sb-card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.1), 0 2px 4px rgba(0,0,0,.06); }
        .sb-card .card-header {
            border-radius: 12px 12px 0 0 !important;
            border-bottom: 1px solid rgba(0,0,0,.05);
        }

        /* ── Tablas ───────────────────────────────────────────────────────── */
        .table > thead > tr > th {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #64748b;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            padding-top: .6rem;
            padding-bottom: .6rem;
        }
        .table tbody tr { transition: background 0.15s ease; }
        .table-hover tbody tr:hover { background-color: #f0f4ff !important; }

        /* ── Estado badges ────────────────────────────────────────────────── */
        .badge-pendiente  { background-color: var(--sb-warning); color: #fff; font-weight: 600; }
        .badge-confirmada { background-color: var(--sb-success); color: #fff; font-weight: 600; }
        .badge-cancelada  { background-color: var(--sb-danger);  color: #fff; font-weight: 600; }

        /* ── Badges Bootstrap override ────────────────────────────────────── */
        .badge.bg-danger  { background-color: var(--sb-danger)  !important; }
        .badge.bg-success { background-color: var(--sb-success) !important; }
        .badge.bg-warning { background-color: var(--sb-warning) !important; color: #fff !important; }
        .badge.bg-info    { background-color: var(--sb-secondary) !important; color: #fff !important; }
        .badge.bg-secondary { background-color: #64748b !important; }

        /* ── Alerts ───────────────────────────────────────────────────────── */
        .alert { border-radius: 10px; border: none; }
        .alert-success { background: #ecfdf5; color: #065f46; }
        .alert-danger  { background: #fef2f2; color: #991b1b; }
        .alert-warning { background: #fffbeb; color: #92400e; }
        .alert-info    { background: #f0f9ff; color: #075985; }

        /* ── Inputs ───────────────────────────────────────────────────────── */
        .form-control, .form-select {
            border-radius: 8px;
            border-color: #e2e8f0;
            font-size: .9rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--sb-primary);
            box-shadow: 0 0 0 3px rgba(99,102,241,.15);
        }
        .input-group-text {
            background: #f8fafc;
            border-color: #e2e8f0;
            color: #64748b;
            border-radius: 8px 0 0 8px;
        }

        /* ── Responsive ───────────────────────────────────────────────────── */
        @media (max-width: 991px) {
            .sb-topnav .navbar-collapse { background: #0f172a; padding: 0.5rem 0 1rem; border-top: 1px solid rgba(255,255,255,0.08); }
            .sb-main-content { padding-left: 1rem; padding-right: 1rem; }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

{% if app.user %}
{# ======================== NAVBAR SUPERIOR ======================== #}
<nav class="navbar navbar-expand-lg sb-topnav fixed-top">
    {# Logo izquierda #}
    <a class="navbar-brand" href="{{ path('app_dashboard') }}">
        <div class="logo-icon">
            <i class="bi bi-calendar-check text-white" style="font-size:1rem"></i>
        </div>
        SmartBooking
    </a>

    {# Hamburguesa móvil #}
    <button class="navbar-toggler ms-auto me-2" type="button"
            data-bs-toggle="collapse" data-bs-target="#sbNavCollapse"
            aria-controls="sbNavCollapse" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="sbNavCollapse">
        {# Links de navegación centro-izquierda #}
        <ul class="navbar-nav me-auto ms-3 gap-1">
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' }}"
                   href="{{ path('app_dashboard') }}">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_booking' ? 'active' }}"
                   href="{{ path('app_booking_index') }}">
                    <i class="bi bi-calendar3"></i> Reservas
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_resource' ? 'active' }}"
                   href="{{ path('app_resource_index') }}">
                    <i class="bi bi-building-fill"></i> Recursos
                </a>
            </li>
            {% if is_granted('ROLE_ADMIN') %}
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_category' ? 'active' }}"
                   href="{{ path('app_category_index') }}">
                    <i class="bi bi-tags-fill"></i> Categorías
                </a>
            </li>
            {% endif %}
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_calendar' ? 'active' }}"
                   href="{{ path('app_calendar') }}">
                    <i class="bi bi-calendar3-week-fill"></i> Calendario
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_empresas' ? 'active' }}"
                   href="{{ path('app_empresas_index') }}">
                    <i class="bi bi-building-fill"></i> Empresas
                </a>
            </li>
        </ul>

        {# Acciones derecha #}
        <div class="d-flex align-items-center gap-2">
            {# Notificaciones (decorativo) #}
            <a href="#" class="sb-notif-btn" title="Notificaciones">
                <i class="bi bi-bell" style="font-size:.95rem"></i>
                <span class="sb-notif-dot"></span>
            </a>

            {# Dropdown de usuario #}
            <div class="dropdown">
                <button class="btn d-flex align-items-center gap-2 p-0 border-0 bg-transparent"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false"
                        style="cursor:pointer">
                    <div class="sb-user-avatar">{{ app.user.initials }}</div>
                    <div class="d-none d-lg-block text-start" style="line-height:1.2">
                        <div style="font-size:.8rem;font-weight:600;color:#e2e8f0">{{ app.user.displayName }}</div>
                        <div style="font-size:.68rem;">
                            {% if is_granted('ROLE_ADMIN') %}
                                <span class="badge" style="background:rgba(239,68,68,.25);color:#fca5a5;font-size:.65rem">
                                    <i class="bi bi-shield-fill me-1"></i>Admin
                                </span>
                            {% elseif is_granted('ROLE_EMPRESA') %}
                                <span class="badge" style="background:rgba(14,165,233,.2);color:#7dd3fc;font-size:.65rem">
                                    <i class="bi bi-building me-1"></i>Empresa
                                </span>
                            {% else %}
                                <span class="badge" style="background:rgba(148,163,184,.15);color:#94a3b8;font-size:.65rem">
                                    <i class="bi bi-person-fill me-1"></i>Persona
                                </span>
                            {% endif %}
                        </div>
                    </div>
                    <i class="bi bi-chevron-down d-none d-lg-inline" style="font-size:.65rem;color:#64748b"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end mt-2">
                    <li>
                        <a class="dropdown-item {{ app.request.attributes.get('_route') starts with 'app_profile' ? 'active' }}"
                           href="{{ path('app_profile_show') }}">
                            <i class="bi bi-person-circle me-2 text-muted"></i>Mi perfil
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>
{% endif %}

{# ======================== CONTENIDO PRINCIPAL ======================== #}
<main class="{{ app.user ? 'sb-main-content' : '' }}">

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show mb-3"
                 role="alert" id="flash-{{ loop.index }}">
                {% if type == 'success' %}<i class="bi bi-check-circle-fill me-2"></i>{% endif %}
                {% if type == 'danger' %}<i class="bi bi-exclamation-triangle-fill me-2"></i>{% endif %}
                {% if type == 'warning' %}<i class="bi bi-exclamation-circle-fill me-2"></i>{% endif %}
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{# ======================== ANGULAR ELEMENTS ======================== #}
{# Angular Elements se inicializan al cargar el bundle.
   <app-root> no se usa: cada componente se registra como Web Component. #}
<app-toast></app-toast>

{# Bootstrap JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{# Angular compiled bundle #}
<script src="{{ asset('build/runtime.js') }}" defer></script>
<script src="{{ asset('build/polyfills.js') }}" defer></script>
<script src="{{ asset('build/main.js') }}" defer></script>

<script>
    // Auto-dismiss flash messages after 5s
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[id^="flash-"]').forEach(el => {
            setTimeout(() => {
                const bsAlert = bootstrap.Alert.getOrCreateInstance(el);
                bsAlert.close();
            }, 5000);
        });

    });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
